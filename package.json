{
  "name": "blogdoagi-cypress-tests",
  "version": "1.0.0",
  "description": "Automação de testes E2E para o Blog do Agi - Funcionalidade de Pesquisa",
  "author": "QA Senior",
  "license": "MIT",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test": "cypress run && npm run allure:generate",
    "test:report": "npm run cy:run && npm run allure:generate && npm run allure:open",
    "clean": "rm -rf allure-results allure-report cypress/screenshots cypress/videos"
  },
  "dependencies": {},
  "devDependencies": {
    "cypress": "^13.6.0",
    "@shelex/cypress-allure-plugin": "^2.40.2",
    "allure-commandline": "^2.27.0"
  }
}
